---
/**
 * GENERIC CONTENT PAGE ROUTE
 * --------------------------
 * Renders any `.md`/`.mdx` file in the `pages` content collection
 * (`src/content/pages/*`) at the URL given by its frontmatter `slug` (falling
 * back to the filename). There is NO per-page route file: adding a new static
 * page means dropping a file into that folder — no routing changes.
 *
 *   ---
 *   title: About IDEMS
 *   slug: idems
 *   template: page       # reading-width prose (default)
 *   ---
 *
 * `template: sections` switches to a full-width, component-driven layout: the
 * design-system blocks (Section, Card, CardGrid) are put in scope for the MDX,
 * so authors use `<Section>` / `<Card>` without importing anything, and the
 * page isn't wrapped in `.prose`. Any other value renders reading-width prose.
 *
 * `getStaticPaths` enumerates the collection at build time and emits one static
 * page per entry.
 */
import { getCollection, render } from 'astro:content';
import Layout from '../components/Layout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import Button from '../components/Button.astro';
import ButtonGroup from '../components/ButtonGroup.astro';
import Rows from '../components/Rows.astro';
import Row from '../components/Row.astro';
import InterestForm from '../components/InterestForm.astro';
import ArchitectureDiagram from '../components/ArchitectureDiagram.astro';
import Steps from '../components/Steps.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    // Frontmatter `slug` wins; otherwise use the entry id (the filename).
    params: { slug: page.data.slug ?? page.id },
    props: { page },
  }));
}

type Props = {
  page: Awaited<ReturnType<typeof getCollection<'pages'>>>[number];
};

const { page } = Astro.props;
const { Content } = await render(page);

const isSections = page.data.template === 'sections';
// Provided to every content page so the MDX resolves `<Section>`, `<Button>`,
// `<InterestForm>` etc. without the author writing import statements.
const contentComponents = {
  Section,
  Card,
  CardGrid,
  Button,
  ButtonGroup,
  Rows,
  Row,
  InterestForm,
  ArchitectureDiagram,
  Steps,
};
---

<Layout
  title={page.data.title}
  description={page.data.description}
  narrow={!isSections}
>
  {
    isSections ? (
      <div class="container content-sections">
        <Content components={contentComponents} />
      </div>
    ) : (
      <article class="container prose">
        <Content components={contentComponents} />
      </article>
    )
  }
</Layout>
