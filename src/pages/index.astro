---
/**
 * Home — short project description, a headline stat, and a link to the
 * catalogue. The textbook count comes from the data layer so it stays accurate
 * as the dataset grows (or is later generated by automation).
 */
import Layout from '../components/Layout.astro';
import { getTextbookCount } from '../lib/textbooks';

const count = await getTextbookCount();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Open Textbook Catalogue"
  description="A minimal, static catalogue of openly hosted digital textbooks."
>
  <div class="container home">
    <section class="hero">
      <p class="hero__eyebrow">Open Textbook Catalogue</p>
      <h1 class="hero__title">
        A library of open statistics textbooks.
      </h1>
      <p class="hero__lede">
        Some intro text here about the project.
      </p>

      <div class="hero__actions">
        <a class="btn btn--primary" href={`${base}/catalogue`}>
          Browse the catalogue
        </a>
        <span class="hero__stat">
          <strong>{count}</strong>
          {count === 1 ? 'textbook' : 'textbooks'} available
        </span>
      </div>
    </section>

    <section class="features">
      <div class="feature">
        <h2 class="feature__title">Reusability/adaptability</h2>
        <p class="feature__text">
          Explanation
        </p>
      </div>
      <div class="feature">
        <h2 class="feature__title">AI agents, with humans in control</h2>
        <p class="feature__text">
          Explanation
        </p>
      </div>
      <div class="feature">
        <h2 class="feature__title">Accessibility</h2>
        <p class="feature__text">
          Explanation
        </p>
      </div>
    </section>
  </div>
</Layout>

<style>
  .hero {
    max-width: var(--reading-width);
    padding-block: var(--space-6) var(--space-8);
  }
  .hero__eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }
  .hero__title {
    font-size: var(--text-3xl);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
  }
  .hero__lede {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }
  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .hero__stat {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .hero__stat strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .features {
    display: grid;
    gap: var(--space-6);
    padding-top: var(--space-8);
    border-top: var(--border);
  }
  .feature__title {
    font-size: var(--text-base);
    margin-bottom: var(--space-2);
  }
  .feature__text {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  @media (min-width: 48rem) {
    .features {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }
  }
</style>
