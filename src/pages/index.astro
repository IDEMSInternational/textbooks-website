---
/**
 * Home — short project description, a headline stat, and a link to the
 * library. 
 */
import Layout from '../components/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Open Textbook Library"
  description="A minimal, static library of openly hosted digital textbooks."
>
  <div class="container home">
    <section class="hero">
      <p class="hero__eyebrow">Adaptive Open Textbooks</p>
      <h1 class="hero__title">
        The high quality, timely, affordable, open resources you need for your course and your students.
      </h1>
      <p class="hero__lede">
        Some intro text here about the project.
      </p>

      <div class="hero__actions">
        <a class="btn btn--primary" href={`${base}/library`}>
          Browse the library
        </a>
        <a class="btn" href={`${base}/join`}>
          Join the community
        </a>
      </div>
    </section>

    <section class="features">
      <div class="feature">
        <h2 class="feature__title">For Educators</h2>
        <p class="feature__tagline">
          <em>Is this “Browse and adapt” — something for your own students?</em>
        </p>
        <p class="feature__lead">
          Easily develop up-to-date, course-relevant textbooks — and include your own work!
        </p>
        <ul class="feature__list">
          <li>Current leading pain point</li>
          <li>Short features list?</li>
          <li>Educators can do x, y, z</li>
          <li>Why it matters — benefits for the user / problems solved / acute pain point(s) addressed</li>
        </ul>
      </div>
      <div class="feature">
        <h2 class="feature__title">For Educator-Authors</h2>
        <p class="feature__tagline">
          <em>Something for your students, and others.</em>
        </p>
        <p class="feature__lead">
          Adapt existing materials to fit your course.
        </p>
        <ul class="feature__list">
          <li>Writing a new book isn’t realistic — but here you can get there</li>
          <li>Short features list?</li>
          <li>Why it matters — benefits for the user / problems solved / acute pain point(s) addressed</li>
        </ul>
      </div>
      <div class="feature">
        <h2 class="feature__title">For Authors</h2>
        <p class="feature__lead">
          Extend the value of your work (?) — see how your work is used, and where and how it gets adapted.
        </p>
        <ul class="feature__list">
          <li>Short features list?</li>
          <li>Why it matters — benefits for the user / problems solved / acute pain point(s) addressed</li>
        </ul>
      </div>
    </section>

    <section class="home-section">
      <h2 class="home-section__title">A great leap forward for teaching and learning</h2>
      <div class="home-section__body">
        <p>
          Existing textbooks are one-size-fits-all and quickly out of date.
          <em>[problems with the textbook and other resources market]</em>
        </p>
        <p>
          New and emerging tech fail to recognise educators’ essential role in
          understanding their specific courses, student needs and contexts.
        </p>
        <p>
          What this means for students, and why this benefits education and outcomes.
        </p>
        <p class="home-note">
          Can we add a bit of research / data on how educator-led customisation and
          context-relevant adaptation improve student outcomes?
        </p>
        <p>
          Educator-centred (not direct-to-student), recognising that educators know
          their students and contexts best.
        </p>
      </div>
    </section>

    <section class="home-section">
      <h2 class="home-section__title">Use cases</h2>
      <ul class="usecases">
        <li>
          Multiple textbooks for a single course, to address the strengths and
          weaknesses of individual students — with common assessment for your course.
        </li>
        <li>Timely translation of changes, edits and versioning.</li>
        <li>
          See how work is used, reused and expanded for creative collaboration —
          enabling collaboration between original authors and adaptation authors,
          with links built in.
        </li>
      </ul>
    </section>

    <section class="home-section">
      <h2 class="home-section__title">Why IDEMS?</h2>
      <p class="home-section__lede">Expertise, trust and social-proof signals.</p>
      <div class="home-section__body">
        <p>
          Why we’re the people to do this.
          <em>[but not getting into About IDEMS — that will be its own page]</em>
        </p>
        <div class="testimonials">
          <figure class="testimonial">
            <blockquote>Testimonial from an existing author.</blockquote>
            <figcaption>— Author <em>(placeholder)</em></figcaption>
          </figure>
          <figure class="testimonial">
            <blockquote>
              Testimonial from an educator — e.g. Roger’s comment on how powerful this
              is for context-relevant customisation.
            </blockquote>
            <figcaption>— Educator <em>(placeholder)</em></figcaption>
          </figure>
          <figure class="testimonial">
            <blockquote>Testimonial from a student?</blockquote>
            <figcaption>— Student <em>(placeholder)</em></figcaption>
          </figure>
        </div>
        <p>
          <a class="btn" href={`${base}/idems`}>Learn more about IDEMS</a>
        </p>
      </div>
    </section>
  </div>
</Layout>

<style>
  .hero {
    max-width: var(--reading-width);
    padding-block: var(--space-6) var(--space-8);
  }
  .hero__eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }
  .hero__title {
    font-size: var(--text-3xl);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
  }
  .hero__lede {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }
  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .hero__stat {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .hero__stat strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .features {
    display: grid;
    gap: var(--space-6);
    padding-top: var(--space-8);
    border-top: var(--border);
  }
  .feature__title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }
  .feature__tagline {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-3);
  }
  .feature__lead {
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }
  .feature__list {
    margin: 0;
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  @media (min-width: 48rem) {
    .features {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }
  }

  .home-section {
    max-width: var(--reading-width);
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: var(--border);
  }
  .home-section__title {
    font-size: var(--text-2xl);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-4);
  }
  .home-section__lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }
  .home-section__body > * + * {
    margin-top: var(--space-4);
  }
  .home-section p {
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }
  .home-section .home-note {
    font-style: italic;
    color: var(--color-text-subtle);
  }
  .usecases {
    margin: 0;
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }
  .testimonials {
    display: grid;
    gap: var(--space-4);
  }
  .testimonial {
    margin: 0;
    padding: var(--space-4) var(--space-5);
    border: var(--border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }
  .testimonial blockquote {
    margin: 0;
    color: var(--color-text);
    line-height: var(--leading-normal);
  }
  .testimonial figcaption {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
