---
/**
 * Home — short project description, a headline stat, and a link to the
 * library. 
 */
import Layout from '../components/Layout.astro';
import Section from '../components/Section.astro';
import CardGrid from '../components/CardGrid.astro';
import Card from '../components/Card.astro';
import Team from '../components/Team.astro';
import AccordionGroup from '../components/AccordionGroup.astro';
import Accordion from '../components/Accordion.astro';
import Steps from '../components/Steps.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Per-audience feature breakdown, revealed via a toggle button on each of
// the Educators / Educator-Authors / Authors cards. `slug` links each
// card's button (data-audience) to its content panel (data-audience-content).
const audienceFeatures = [
  {
    slug: 'educators',
    name: 'Educators',
    tagline: 'Adapt & Iterate',
    features: [
      {
        title: 'Find the right foundation',
        body: 'Discover a growing library of free, open textbooks and resources ready to use and adapt.',
        note: 'Move beyond searching through scattered resources or relying on textbooks that are outdated, locked behind paywalls, or difficult to modify.',
      },
      {
        title: 'Adapt materials to your students',
        body: 'Change examples, datasets, assessments, explanations, and activities to match your learners and your teaching goals.',
        note: 'Teach core concepts through content that feels relevant, meaningful, and accessible to your students.',
      },
      {
        title: 'Choose the variant that fits',
        body: 'Choose or build on variants created for different audiences, tools, and disciplines.',
        note: 'Avoid one-size-fits-all textbooks and build learning experiences that reflect the diversity of your students.',
      },
      {
        title: 'Improve your course over time',
        body: 'Continuously refine resources as your course and students evolve.',
        note: 'Keep your resources current while contributing to a community of educators who are continuously improving teaching and learning.',
      },
    ],
  },
  {
    slug: 'educator-authors',
    name: 'Educator-Authors',
    tagline: 'Adapt & Innovate',
    features: [
      {
        title: 'Start from “What Works”',
        body: 'Build on existing open textbooks and resources instead of starting from a blank page.',
        note: 'Remove the biggest barriers to textbook creation, time, cost, and expertise, so more educators can become authors.',
      },
      {
        title: 'Create your own variant',
        body: 'Add your examples, datasets, assessments, explanations, and activities to develop a textbook that fits your course.',
        note: 'Transform a good textbook into the right textbook for your students and your context.',
      },
      {
        title: 'Collaborate beyond the classroom',
        body: 'Share your adaptations and build on the work of other educators.',
        note: 'Move from isolated course materials to a community where teaching innovations can be reused and improved.',
      },
      {
        title: 'Get recognised for your contribution',
        body: 'Publish your adapted textbook variant and receive attribution as a contributor to the open library.',
        note: 'Your teaching expertise becomes a visible contribution that helps others while building your academic profile.',
      },
    ],
  },
  {
    slug: 'authors',
    name: 'Authors',
    tagline: 'Create & Evolve',
    features: [
      {
        title: 'Make your work reusable',
        body: 'Create resources that can be adapted across platforms, formats, and teaching contexts.',
        note: 'Keep your textbook accessible and valuable as technology, disciplines, and learner needs change.',
      },
      {
        title: 'Extend your textbook’s reach',
        body: 'Enable educators to discover, adopt, and adapt your work for new audiences.',
        note: 'Help your ideas reach learners and communities beyond the original context you designed them for.',
      },
      {
        title: 'Understand your impact',
        body: 'Gain insight into how your resources are being used, adapted, and built upon.',
        note: 'See the real-world influence of your work and discover new opportunities for collaboration.',
      },
      {
        title: 'Evolve with the community',
        body: 'Use feedback and contributions from educators to improve future versions of your textbook.',
        note: 'Keep your work alive, current, and continuously improving alongside your field.',
      },
    ],
  },
];

---

<Layout
  title="Open, Adaptive Digital Textbooks"
  description="A minimal, static library of openly hosted digital textbooks."
>
  <div class="container home">
    <section class="hero">
      <div class="hero__content">
        <h1 class="hero__title">
          Open, Adaptive Statistics
          <br>
          & Data Science Textbooks
        </h1>
        <p class="hero__lede">
          High-quality teaching and learning digital textbooks and resources.
          <br>Created by subject-matter experts, customised by expert educators,
          <br>improved everywhere to benefit everyone.
        </p>

        <div class="hero__actions">
          <a class="btn btn--primary" href={`${base}/innovation`}>
            Explore the innovation
          </a>
          <a class="btn btn--secondary" href={`${base}/join`}>
            Join the community
          </a>
        </div>
      </div>

      <div class="hero__media">
        <img
          class="hero__image"
          src={`${base}/images/colour-explosion.gif`}
          alt=""
          width="700"
          height="700"
        />
      </div>
    </section>

    <Section
      tone="dark"
      eyebrow="The unsolved problem"
    >
      <Fragment slot="title">
        Existing textbooks aren’t a match
        <br class="soft-break" />
        for a complex, rapidly changing world.
      </Fragment>
      <div class="section-lead">
        <p>
          A global community of educators and authors are committed to
          developing a flourishing ecosystem of open, accessible textbooks
          and educational resources to make high-quality teaching and
          learning accessible to all.
        </p>
        <p>
          But from the moment they’re created, even the best textbooks need
          adaptation, updating and iteration to meet the needs of individual
          educators–and their courses and students.
        </p>
      </div>

      <CardGrid>
        <Card title="New & Emerging Technologies">
          <p>
            Core concepts stay the same, but <em>how</em> and <em>where</em>
            they’re applied are constantly changing. As a result, existing
            textbooks and resources are quickly out of date, misaligned, or
            only stay relevant by failing to address new technologies and
            innovation altogether.
          </p>
        </Card>
        <Card title="Variable Contextual Realities">
          <p>
            Teaching and learning happen better when resources are relevant
            and accessible. But existing textbooks can’t easily adapt into
            new cultural or language contexts; incorporate different
            examples, datasets or tools; or account for limited access in
            low-resource contexts.
          </p>
        </Card>
        <Card title="Different Strengths and Weaknesses">
          <p>
            Even within a single course, students have varying strengths and
            weaknesses. But existing textbooks are one-size-fits-all, unable
            to flex to serve students with targeted resources, low-stakes
            assessment, or additional support to help them learn better.
          </p>
        </Card>
      </CardGrid>
    </Section>

    <Section
      eyebrow="The solution"
      eyebrowAccent2
      titleEmphasis
    >
      <Fragment slot="title">
        Open, <em>adaptive</em> educational resources:
        <br />
        A great leap forward for teaching and learning
      </Fragment>

      <div class="section-lead solution-lead">
        <p>
          IDEMS is introducing a living library of high-quality open
          statistics and data science textbooks (and supporting teaching,
          learning and assessment resources) that can be tailored to any
          course, context, and/or student. Educators develop entirely new
          textbooks without starting from scratch–or creating an isolated
          copy that requires constant upkeep.
        </p>
        <p class="solution-lead__setup">
          With IDEMS’ <strong>Open, Adaptive Statistics &amp; Data Science
          Textbooks</strong>, educators can:
        </p>
        <ul class="section-lead__list">
          <li>
            Easily recombine existing open textbooks and resources to shape
            new versions for unique courses and students
          </li>
          <li>Swap or add new examples, datasets, or assessments</li>
          <li>Translate an entire textbook or section in real time.</li>
          <li>
            Decide what delivery format works best for a unique context and
            students
          </li>
          <li>
            Contribute to the ongoing development of an ever-expanding,
            peer-reviewed textbook and resource library
          </li>
        </ul>
        <p>
          New textbook and resource versions developed out of our system
          stay connected: your adaptations and improvements help other
          educators and authors, and theirs help yours.
        </p>
      </div>

      <p class="section-subhead">How it works for:</p>

      <CardGrid>
        <Card title="Educators">
          <p>
            Easily create the precise textbook and supporting resources for
            <em>your</em> course and <em>your</em> students, from an
            ever-expanding suite of high-quality open textbooks and
            educational resources.
          </p>
          <button
            type="button"
            class="audience-toggle"
            data-audience="educators"
            aria-expanded="false"
            aria-controls="audience-panel"
          >
            See how it works
            <svg class="audience-toggle__chevron" viewBox="0 0 16 16" aria-hidden="true">
              <path
                d="M4 6l4 4 4-4"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>
        </Card>
        <Card title="Educator-Authors">
          <p>
            Build a customised textbook from open textbooks, and layer in new lessons, resources, and assessments. Submit it for community review to earn recognition for your contribution.
          </p>
          <button
            type="button"
            class="audience-toggle"
            data-audience="educator-authors"
            aria-expanded="false"
            aria-controls="audience-panel"
          >
            See how it works
            <svg class="audience-toggle__chevron" viewBox="0 0 16 16" aria-hidden="true">
              <path
                d="M4 6l4 4 4-4"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>
        </Card>
        <Card title="Authors">
          <p>
            Extend the value of your textbooks, and understand where and how
            educators are using them to improve your existing textbooks and
            to develop entirely new textbooks and resources.
          </p>
          <button
            type="button"
            class="audience-toggle"
            data-audience="authors"
            aria-expanded="false"
            aria-controls="audience-panel"
          >
            See how it works
            <svg class="audience-toggle__chevron" viewBox="0 0 16 16" aria-hidden="true">
              <path
                d="M4 6l4 4 4-4"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>
        </Card>
      </CardGrid>

      <div class="audience-panel" id="audience-panel" hidden>
        {
          audienceFeatures.map((audience) => (
            <div class="audience-panel__inner" data-audience-content={audience.slug} hidden>
              <p class="audience-panel__tagline">
                {audience.name} · <em>{audience.tagline}</em>
              </p>
              <Steps steps={audience.features} />
            </div>
          ))
        }
      </div>

      <p class="solution-link">
        <a class="btn btn--primary" href={`${base}/innovation`}>
          Explore the architecture
        </a>
      </p>
    </Section>

    <Section
      tone="tinted"
      eyebrow="Use cases"
      title="Centring educators, empowering local innovation, transforming authoring, teaching and learning"
      narrow
    >
      <div class="section-lead">
        <p>
          <strong>IDEMS’ Open, Adaptive Digital Textbooks</strong> reinvent what a textbook can be. Instead of a fixed, finished artefact, it's a living resource reshaped by the educators who use it.
        </p>
        <p>What does that look like in practice?</p>
        <p>
          Meet three educators using <strong>Open, Adaptive Statistics &amp;
          Data Science Textbooks</strong> to solve three different problems:
        </p>
        <ol class="section-lead__list">
          <li>swapping programming language application</li>
          <li>splitting one course into several tailored versions, and</li>
          <li>entirely reshaping content for a new audience and context.</li>
        </ol>
        <p>
          Each adaptation stays connected to the whole, and benefits everyone
          else, growing the library instead of forking away from it.
        </p>
      </div>

      <AccordionGroup>
        <Accordion title="Example 1 – Same Concepts, Different Applications">
          <p>
            <em>An Introduction to Data Science</em> is Dr. Lily Clements’
            favourite textbook, but it uses R and this year she’s teaching
            her students to code with Python.
          </p>
          <p>
            Rather than starting from scratch, she creates a new textbook
            variant. She takes the textbook and replaces R examples with
            Python, updates code snippets, and tailors the embedded
            assessments in the existing textbook to develop an entirely new
            textbook: <em>An Introduction to Data Science with Python</em>.
          </p>
          <p>
            When she's ready, she shares her adaptation with the community.
            Following peer review, her textbook is recognised as a curated
            contribution to the open library. She receives attribution as
            the author of the adaptation, while the original authors
            continue to receive credit for the foundation on which it was
            built.
          </p>
          <p>
            She is now both an educator and an author, with her
            peer-reviewed textbook contributing to the continuously
            evolving open library. Future educators can adopt her version,
            adapt it for their own contexts, or build on it further –
            creating a living ecosystem of textbooks that evolves alongside
            the discipline.
          </p>
        </Accordion>
        <Accordion title="Example 2 – One Course, Multiple Textbooks">
          <p>
            Dr. David Stern is a guest lecturer at Maseno University in
            Kenya, teaching an <em>Introduction to Data Science for Social
            Impact</em> course. His students come from diverse academic
            backgrounds, with varying levels of experience in data
            analysis, programming, and statistical thinking.
          </p>
          <p>
            Rather than creating a one-size-fits-all textbook, David builds
            multiple versions of the same foundational course resource.
            Each version shares the same core concepts and learning
            objectives but includes different examples, explanations,
            exercises, and assessments to support students with different
            needs.
          </p>
          <p>
            Students receive materials that better match their needs, while
            still progressing towards shared learning goals. Over time,
            these adapted versions become part of a growing library of
            resources that educators can reuse, refine, and customise for
            their own learners.
          </p>
        </Accordion>
        <Accordion title="Example 3 – Context-Relevant Examples and Datasets">
          <p>
            <em>Statistical Thinking for the 21st Century</em> is a highly
            regarded open textbook for introducing statistics to beginners.
            However, its examples and datasets are designed primarily for
            STEM students in US universities. Professor Roger Stern is
            preparing a course on statistical analysis of historical
            weather data for a local Meteorological Office team in
            Zimbabwe.
          </p>
          <p>
            Rather than starting from scratch, he adapts the existing
            textbook by replacing examples, datasets, and tools with
            materials that reflect the team’s own work and local context.
            The statistical concepts remain the same, but the team learn
            through data and problems that are directly relevant to their
            roles: analysing climate patterns, interpreting historical
            records, and applying statistical methods to real-world
            decisions.
          </p>
          <p>
            Roger’s adaptation transforms an existing open resource into a
            specialised textbook for a new audience, while contributing a
            valuable version back to the open library for others to
            discover, adapt, and build upon.
          </p>
        </Accordion>
      </AccordionGroup>
    </Section>

    <Section>
      <Fragment slot="title">
        What people are saying about
        <br />
        <span class="title-accent">Open, Adaptive Statistics &amp; Data Science Textbooks</span>
      </Fragment>
      <div class="testimonials">
        <figure class="testimonial">
          <blockquote>
            Statistics becomes much more meaningful when learners can see
            themselves in the examples. By working with real climate data and
            problems that professionals encounter every day, we can move
            beyond teaching statistical methods in isolation and help people
            develop skills they can immediately apply in their work.
          </blockquote>
          <figcaption>— Dr. Roger Stern, Educator</figcaption>
        </figure>
        <figure class="testimonial">
          <blockquote>
            I got my start by essentially “recontextualizing” some material
            that someone else had been generous enough to put into the public
            domain. […] I don’t think I ever would have had the ambition to
            write a book from scratch, but adaptable open educational
            materials allowed me to get started and realize that I could
            write much more than I expected in the beginning.
          </blockquote>
          <figcaption>
            — Nathan Favero, Author of <em>Statistics Minus The Math</em>
          </figcaption>
        </figure>
        <figure class="testimonial">
          <blockquote>
            So often people don't inform folks in the OER world (e.g., an OER
            of mine on number theory and cryptography was being heavily used
            at a university in Chile, and I only happened to stumble upon
            that fact by accident!), and while it is perfectly legal, it is
            such a kindness to share this information.
          </blockquote>
          <figcaption>
            — Jonathan A. Poritz, Author of <em>Lies, Damned Lies, or Statistics</em>
          </figcaption>
        </figure>
      </div>
    </Section>

    <Section>
      <Fragment slot="title">
        IDEMS: Where statistics, education,
        <br />
        mathematics and tech meet
      </Fragment>
      <div class="section-lead">
        <p>
          UK-based IDEMS is a social enterprise building open,
          community-owned technology for global impact.
          <strong>Open, Adaptive Statistics &amp; Data Science Textbooks</strong>
          emerge from our understanding of the need for deeply technical
          educator-centred innovation that supports global collaboration and
          local adaptation.
        </p>
        <p>
          IDEMS’ team of mathematical scientists and software engineers
          bring decades of technical expertise, field-level pedagogical
          understanding, and direct teaching experience. We work with
          educators around the world to reimagine how technology can
          support, rather than replace or marginalise, educators to improve
          teaching and learning for everyone.
        </p>
        <p>The team includes:</p>
      </div>

      <Team />

      <p class="team__more">
        <a class="btn btn--primary" href={`${base}/idems`}>Learn more about IDEMS</a>
      </p>
    </Section>
  </div>
</Layout>

<script>
  import '../scripts/audience-toggle.ts';
</script>

<style>
  /* Deliberate line break in the "Existing textbooks aren't a match…"
     headline — suppressed on narrow screens where it could land awkwardly. */
  .soft-break {
    display: none;
  }
  @media (min-width: 30rem) {
    .soft-break {
      display: block;
    }
  }

  /* Accent-coloured run within a section title (e.g. the product name on its
     own line). */
  .title-accent {
    color: var(--color-accent);
  }

  .hero {
    padding-block: var(--space-8) var(--space-10);
  }
  .hero__content {
    max-width: var(--reading-width);
  }
  .hero__media {
    margin-top: var(--space-6);
  }
  .hero__image {
    display: block;
    width: 100%;
    max-width: 24rem;
    height: auto;
    border-radius: var(--radius);
  }

  /* Two columns once there's room: content left, animated media right. Below
     this the media stacks under the content (see .hero__media margin above). */
  @media (min-width: 50rem) {
    .hero {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: var(--space-8);
    }
    .hero__content {
      max-width: none;
    }
    .hero__media {
      margin-top: 0;
      width: 24rem;
    }
  }

  .hero__eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }
  .hero__title {
    /* Bigger than the section-title scale below, so the hero clearly reads
       as the page's lead statement. */
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
  }
  .hero__lede {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }
  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .hero__stat {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .hero__stat strong {
    color: var(--color-text);
    font-weight: 600;
  }

  /* Reading-width intro (text + bullets) used across several sections. */
  .section-lead {
    max-width: var(--reading-width);
    margin-bottom: var(--space-8);
  }
  .section-lead > * + * {
    margin-top: var(--space-4);
  }
  .section-lead p {
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }
  .section-lead__list {
    margin: 0;
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* Solution section's intro copy. The opening and closing paragraphs sit at
     the normal section-lead indent; between them the italic "educators can:"
     set-up line and the bullet list it introduces are indented a step further,
     so the two of them read as a distinct callout. */
  .solution-lead__setup {
    margin-left: var(--space-6);
  }
  /* The list shares the set-up line's indent, and is pulled up closer than the
     section-lead default gap so it reads as introducing the list directly,
     not just another paragraph in the sequence. */
  .solution-lead__setup + .section-lead__list {
    margin-left: var(--space-6);
    margin-top: var(--space-2);
  }

  /* Plain text link (not a button) to the Innovation page, placed below the
     audience boxes rather than breaking up the intro copy. */
  .solution-link {
    margin-top: var(--space-8);
    text-align: center;
  }

  .section-subhead {
    font-weight: 600;
    margin-bottom: var(--space-5);
  }

  /* Per-card toggle button (in each Educators/Educator-Authors/Authors
     Card) that opens the shared, full-width panel below the row. */
  .audience-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding: 0;
    border: none;
    background: none;
    font: inherit;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    cursor: pointer;
  }
  .audience-toggle:hover {
    color: var(--color-accent-hover);
  }
  .audience-toggle__chevron {
    width: 0.85rem;
    height: 0.85rem;
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }
  .audience-toggle[aria-expanded='true'] .audience-toggle__chevron {
    transform: rotate(180deg);
  }

  /* Shared panel: bubbles out directly below the card row. Capped at reading
     width rather than the full row width — this is stepped, single-column
     text, and a bordered/backgrounded box that's much wider than its content
     just reads as dead space, not intentional whitespace. Only the
     `[data-audience-content]` block matching the active toggle is shown;
     see scripts/audience-toggle.ts. */
  .audience-panel {
    max-width: var(--reading-width);
    margin-top: var(--space-5);
    padding: var(--space-5);
    border: var(--border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }
  .audience-panel__tagline {
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }
  .audience-panel__tagline em {
    font-weight: 400;
    color: var(--color-text-subtle);
  }

  /* Running-text body for narrow Sections (paragraphs, lists, testimonials). */
  .home-body > * + * {
    margin-top: var(--space-4);
  }
  .home-body p {
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }
  .testimonials {
    margin-top: var(--space-8);
    display: grid;
    gap: var(--space-5);
  }
  @media (min-width: 48rem) {
    .testimonials {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .testimonial {
    margin: 0;
    display: flex;
    flex-direction: column;
    padding: var(--space-5);
    border: var(--border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }
  .testimonial blockquote {
    margin: 0;
    /* Push the attribution to the card bottom so rows line up. */
    flex: 1 1 auto;
    color: var(--color-text);
    line-height: var(--leading-normal);
  }
  /* Oversized accent quotation mark as a decorative lead-in. */
  .testimonial blockquote::before {
    content: '\201C';
    display: block;
    margin-bottom: var(--space-1);
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    line-height: 1;
    color: var(--color-accent);
  }
  .testimonial figcaption {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: var(--border);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  /* "Learn more about IDEMS" CTA below the <Team /> roster. */
  .team__more {
