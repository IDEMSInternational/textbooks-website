---
/**
 * Library — the primary feature page.
 *
 * This is a STATIC page: all textbook cards are rendered at build time, and the
 * filter/search work happens entirely client-side (see `scripts/library.ts`).
 * The client reads the URL on load, sets the controls, and shows/hides cards.
 *
 * `initialState` is parsed from the URL and passed to the controls so they
 * prefill correctly under SSR/hybrid hosting. Under static hosting the build
 * has no query string, so it is empty here and the client takes over on load.
 * A tiny inline "flash guard" (below) hides the cards on a filtered deep-link
 * until the client has applied the filters, so shared links don't flash.
 */
import Layout from '../components/Layout.astro';
import FilterPanel from '../components/FilterPanel.astro';
import SearchBar from '../components/SearchBar.astro';
import TextbookCard from '../components/TextbookCard.astro';
import { getTextbooks, getFacets } from '../lib/textbooks';
import { stateFromParams } from '../lib/filtering';

const books = await getTextbooks();
const facets = await getFacets();
const initialState = stateFromParams(Astro.url.searchParams);
---

<Layout
  title="Library"
  description="Browse and filter the catalogue of openly hosted digital textbooks."
>
  {/* Flash guard: if the URL carries filters, hide results until the client
      script applies them. Runs synchronously before the cards below are
      painted. No-JS visitors never reach this branch, so they see all cards. */}
  <script is:inline>
    if (new URLSearchParams(location.search).toString()) {
      document.documentElement.classList.add('is-prefiltering');
    }
  </script>

  <div class="container library" data-library>
    <header class="library__intro">
      <h1>Library</h1>
      <p class="library__lede">
        Browse <span data-total-count>{books.length}</span> openly hosted
        digital textbooks. Filter by language, software and subject, or search
        across titles, descriptions, keywords and authors.
      </p>
    </header>

    <div class="library__toolbar">
      <SearchBar initialValue={initialState.search} />
    </div>

    <div class="library__layout">
      <aside class="library__sidebar">
        <FilterPanel facets={facets} selected={initialState.facets} />
      </aside>

      <section class="library__results" aria-label="Search results">
        <p class="library__count" role="status" aria-live="polite">
          Showing <strong data-result-count>{books.length}</strong> of
          <span data-total-count>{books.length}</span> textbooks
        </p>

        <ul class="library__grid" role="list">
          {
            books.map((book) => (
              <li>
                <TextbookCard book={book} />
              </li>
            ))
          }
        </ul>

        <p class="library__empty" data-empty-state hidden>
          No textbooks match the current filters. Try removing a filter or
          clearing your search.
        </p>
      </section>
    </div>
  </div>
</Layout>

<script>
  import '../scripts/library.ts';
</script>

<style>
  .library__intro {
    max-width: var(--reading-width);
    margin-bottom: var(--space-6);
  }
  .library__intro h1 {
    font-size: var(--text-3xl);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .library__lede {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
  }

  .library__toolbar {
    margin-bottom: var(--space-6);
    max-width: 36rem;
  }

  .library__layout {
    display: grid;
    gap: var(--space-6);
  }

  .library__count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }
  .library__count strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .library__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }
  /* Explicitly collapse hidden grid items (the client toggles `hidden` on the
     <li>). Guarantees the cell is removed regardless of UA `[hidden]` rules. */
  .library__grid li[hidden] {
    display: none;
  }

  .library__empty {
    margin-top: var(--space-4);
    padding: var(--space-8) var(--space-5);
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    border: 1px dashed var(--color-border-strong);
    border-radius: var(--radius);
    background: var(--color-surface);
  }

  /* Sidebar on the left from tablet up; stacked on mobile. */
  @media (min-width: 48rem) {
    .library__layout {
      grid-template-columns: 14rem 1fr;
      align-items: start;
      gap: var(--space-8);
    }
    .library__sidebar {
      position: sticky;
      top: var(--space-5);
    }
  }

  @media (min-width: 64rem) {
    .library__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
