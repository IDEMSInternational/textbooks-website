---
/**
 * Card — a titled content block, intended for use inside a `CardGrid` but fine
 * standalone. The heading text is a prop; the body is the default slot so
 * callers can pass a paragraph, a list, links, etc.
 *
 * The title renders as an <h3>, matching the card-title level used elsewhere
 * (see TextbookCard) and sitting correctly under a typical section <h2>.
 *
 * `variant="plain"` drops the border, background and padding for a borderless
 * cell — e.g. a feature in a grid where the card chrome would be too heavy.
 */
interface Props {
  title: string;
  variant?: 'default' | 'plain';
}

const { title, variant = 'default' } = Astro.props;
---

<article class:list={['card', { 'card--plain': variant === 'plain' }]}>
  <h3 class="card__title">{title}</h3>
  <div class="card__body">
    <slot />
  </div>
</article>

<style>
  .card {
    border: var(--border);
    border-radius: var(--radius);
    background: var(--color-bg);
    padding: var(--space-5);
    transition:
      border-color 0.12s ease,
      box-shadow 0.12s ease;
  }
  .card:hover {
    border-color: var(--color-border-strong);
    box-shadow: 0 1px 3px rgba(24, 24, 27, 0.06);
  }
  .card--plain {
    border: none;
    background: none;
    padding: 0;
  }
  .card--plain:hover {
    box-shadow: none;
  }
  .card__title {
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-2);
  }
  .card__body {
    /* Matches the site's standard body-text size — was a step smaller, which
       read as inconsistent with running text elsewhere on the page. */
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }
  .card__body > :global(* + *) {
    margin-top: var(--space-3);
  }
</style>
