---
/**
 * StatusBadge — a small accent-tinted capsule with a leading status dot, for
 * flagging a stage/status (e.g. "Early prototype"). Used both as <Section>'s
 * `eyebrowBadge` and standalone on non-Section pages (e.g. the Library header),
 * so the styling lives here once.
 *
 * Colours derive from --color-accent, so it adapts on tinted/dark sections
 * where that token is re-declared; browsers without color-mix fall back to a
 * plain accent-outlined pill. The --space-4 bottom margin sets it apart from
 * whatever follows (a section title, a page heading).
 */
interface Props {
  label: string;
}
const { label } = Astro.props;
---

<span class="status-badge">{label}</span>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    padding: var(--space-1) var(--space-3);
    border-radius: 999px;
    border: 1px solid var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
  }
  .status-badge::before {
    /* Small status dot — reinforces the "stage/status" reading. */
    content: '';
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }
</style>
