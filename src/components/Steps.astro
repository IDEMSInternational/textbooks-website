---
/**
 * Steps — a vertical, numbered step sequence: each step is a filled number in a
 * circle, joined to the next by a connecting line, beside a title, body, and
 * optional note. Steps auto-number from 1 in source order.
 *
 * With `collapsible`, each step becomes a native <details>/<summary> disclosure
 * (closed by default): the number + title + caret form the button, and the
 * body/note are revealed on expand. The numbered circles and connecting line
 * are shared with the default (always-open) layout.
 *
 * Purely presentational: it renders the list of `steps` passed to it and owns
 * no cross-step "only one open" behaviour. The visible circle number is
 * decorative (aria-hidden); a matching "Step N:" prefix is added visually-hidden
 * to each title so the sequence still reads correctly to assistive tech. Titles
 * therefore should NOT include their own "Step N:" label — the component
 * supplies the numbering.
 */
interface Step {
  title: string;
  /** Optional date/label shown after the title, de-emphasised (not bold). */
  date?: string;
  body: string;
  note?: string;
}

interface Props {
  steps: Step[];
  /** Render each step as a collapsible disclosure, closed by default. */
  collapsible?: boolean;
}

const { steps, collapsible = false } = Astro.props;
---

<ol class:list={['steps', { 'steps--collapsible': collapsible }]}>
  {
    steps.map((step, i) => (
      <li class="steps__item">
        {collapsible ? (
          <details class="steps__details">
            <summary class="steps__summary">
              <span class="steps__number" aria-hidden="true">
                {i + 1}
              </span>
              <span class="steps__title">
                <span class="visually-hidden">Step {i + 1}: </span>
                {step.title}
                {step.date && <span class="steps__date">{' '}({step.date})</span>}
              </span>
              <svg class="steps__caret" viewBox="0 0 16 16" aria-hidden="true">
                <path
                  d="M4 6l4 4 4-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </summary>
            <div class="steps__reveal">
              <p class="steps__body">{step.body}</p>
              {step.note && <p class="steps__note">{step.note}</p>}
            </div>
          </details>
        ) : (
          <Fragment>
            <span class="steps__number" aria-hidden="true">
              {i + 1}
            </span>
            <div class="steps__content">
              <p class="steps__title">
                <span class="visually-hidden">Step {i + 1}: </span>
                {step.title}
                {step.date && <span class="steps__date">{' '}({step.date})</span>}
              </p>
              <p class="steps__body">{step.body}</p>
              {step.note && <p class="steps__note">{step.note}</p>}
            </div>
          </Fragment>
        )}
      </li>
    ))
  }
</ol>

<style>
  .steps {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .steps__item {
    position: relative;
    display: grid;
    grid-template-columns: 1.75rem 1fr;
    column-gap: var(--space-4);
    padding-bottom: var(--space-5);
  }
  .steps__item:last-child {
    padding-bottom: 0;
  }
  .steps__number {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #ffffff;
    font-size: var(--text-sm);
    font-weight: 600;
  }
  /* Connecting line: spans from the bottom of this item's circle down to the
     bottom of the `<li>` box (i.e. to where the next circle starts), so it
     adapts to each step's content height instead of assuming a fixed distance
     between circles. */
  .steps__item:not(:last-child)::before {
    content: '';
    position: absolute;
    top: 1.75rem;
    bottom: 0;
    left: calc(1.75rem / 2 - 1px);
    width: 2px;
    background: var(--color-border-strong);
  }
  .steps__title {
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }
  /* Trailing date/label — de-emphasised against the bold title. */
  .steps__date {
    font-weight: 400;
    color: var(--color-text-muted);
  }
  /* Standard site body size, not a step smaller. */
  .steps__body,
  .steps__note {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }
  .steps__note {
    margin-top: var(--space-2);
    font-style: italic;
    color: var(--color-text-subtle);
  }

  /* ---- Collapsible (accordion) variant ---- */
  /* Each step's title becomes a <summary> button toggling its body/note; the
     circles and connecting line above are reused as-is. Non-collapsible
     instances (e.g. the homepage) keep the always-open grid layout untouched. */
  .steps--collapsible .steps__item {
    display: block;
    padding-bottom: var(--space-4);
  }
  .steps--collapsible .steps__summary {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    list-style: none;
    cursor: pointer;
  }
  .steps--collapsible .steps__summary::-webkit-details-marker {
    display: none;
  }
  .steps--collapsible .steps__title {
    flex: 1;
    /* Title lives in the summary now, so drop the gap-to-body it carries in the
       always-open layout. */
    margin-bottom: 0;
  }
  .steps--collapsible .steps__caret {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    /* Nudge down to sit against the title's first line, not the circle top. */
    margin-top: 0.3rem;
    color: var(--color-accent);
    transition: transform 0.15s ease;
  }
  .steps--collapsible .steps__details[open] .steps__caret {
    transform: rotate(180deg);
  }
  /* Revealed body/note, indented to line up under the title (past the circle). */
  .steps--collapsible .steps__reveal {
    padding-top: var(--space-2);
    padding-left: calc(1.75rem + var(--space-4));
  }
</style>
