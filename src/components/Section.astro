---
/**
 * Section — a page section with an optional head (eyebrow/title/subtitle) over
 * a body (the default slot). Owns the divider and vertical rhythm between page
 * sections, so callers just drop content into the slot.
 *
 * The head is capped at reading width for legibility. The body spans the full
 * container by default so it can hold wide content such as a `CardGrid`; pass
 * `narrow` to cap it at reading width for running text. Omit the title (and
 * eyebrow/subtitle) for a headless band, e.g. a bare feature grid.
 *
 * For a plain title pass the `title` prop; for a rich one (emphasis, line
 * breaks) pass a `title` slot instead, which takes precedence.
 *
 * `tone` renders a full-bleed colour band with no per-element styling needed:
 * "dark" re-declares the colour tokens so descendant text and cards invert
 * automatically (with a mint highlight); "tinted" is a pale grey-blue band that
 * keeps the default orange highlight.
 *
 * `titleEmphasis` is for the rare section that needs to outrank its neighbours
 * (e.g. a "solution" following a "problem" section) — centers the title and
 * colours it with the accent.
 *
 * `eyebrowBadge` renders the eyebrow as a status pill (the shared
 * <StatusBadge> — an accent-tinted, dot-prefixed capsule) instead of plain
 * uppercase text, for a stage/status flag (e.g. "Now in early prototype") that
 * should read as its own contained badge rather than a normal section eyebrow.
 *
 * `centeredHead` is the light-touch version of `titleEmphasis`: just centers
 * the eyebrow/title/subtitle, with no size or colour change, for a section
 * that wants a bit of visual variety without competing for attention.
 *
 * `eyebrowAccent2` colours the eyebrow with the secondary (blue) accent
 * instead of the default orange — for a section that wants its eyebrow to
 * stand out from neighbouring sections' eyebrows.
 *
 * `titleLineBreak` renders an embedded "\n" in a plain `title` string as a
 * line break. Only needed on MDX pages: a `title` slot's content there gets
 * markdown-parsed, which wraps each line in its own (invalid inside <h2>)
 * <p> — so MDX callers pass a plain string with a literal "\n" instead, and
 * opt into this to render it. Off by default so it doesn't affect `title`
 * slots (e.g. on .astro pages), whose own JSX-formatting whitespace/newlines
 * would otherwise start rendering as unwanted extra line breaks too.
 *
 * `titleHighlight` accent-colours a single phrase within a plain-string
 * `title`, leaving the rest in the default text colour (e.g. "IDEMS
 * Middleware: …" with only "IDEMS Middleware" orange). It's the partial
 * counterpart to `titleEmphasis`, which accents the whole line — and works on
 * MDX pages, where the string `title` prop is the only way to mark up a title.
 */
import StatusBadge from './StatusBadge.astro';

interface Props {
  title?: string;
  eyebrow?: string;
  subtitle?: string;
  narrow?: boolean;
  tone?: 'default' | 'dark' | 'tinted';
  titleEmphasis?: boolean;
  eyebrowBadge?: boolean;
  centeredHead?: boolean;
  eyebrowAccent2?: boolean;
  titleLineBreak?: boolean;
  titleHighlight?: string;
}

const {
  title,
  eyebrow,
  subtitle,
  narrow = false,
  tone = 'default',
  titleEmphasis = false,
  eyebrowBadge = false,
  centeredHead = false,
  eyebrowAccent2 = false,
  titleLineBreak = false,
  titleHighlight,
} = Astro.props;
const hasTitleSlot = Astro.slots.has('title');
const hasTitle = hasTitleSlot || Boolean(title);
const hasHead = Boolean(eyebrow) || hasTitle || Boolean(subtitle);

// Split a plain-string `title` around `titleHighlight` so that phrase can be
// accent-coloured while the rest stays the default text colour. Only applies
// when the phrase is actually present; otherwise the title renders untouched.
const highlightAt =
  title && titleHighlight ? title.indexOf(titleHighlight) : -1;
const titleParts =
  highlightAt >= 0 && title && titleHighlight
    ? {
        before: title.slice(0, highlightAt),
        highlight: titleHighlight,
        after: title.slice(highlightAt + titleHighlight.length),
      }
    : null;
---

<section
  class:list={[
    'section',
    { 'section--dark': tone === 'dark', 'section--tinted': tone === 'tinted' },
  ]}
>
  {
    hasHead && (
      <div
        class:list={[
          'section__head',
          {
            'section__head--emphasis': titleEmphasis,
            'section__head--centered': centeredHead,
          },
        ]}
      >
        {eyebrow &&
          (eyebrowBadge ? (
            <StatusBadge label={eyebrow} />
          ) : (
            <p
              class:list={[
                'section__eyebrow',
                { 'section__eyebrow--accent2': eyebrowAccent2 },
              ]}
            >
              {eyebrow}
            </p>
          ))}
        {hasTitle && (
          <h2
            class:list={[
              'section__title',
              {
                'section__title--emphasis': titleEmphasis,
                'section__title--line-break': titleLineBreak,
                'section__title--highlighted': titleParts,
              },
            ]}
          >
            {
              hasTitleSlot ? (
                <slot name="title" />
              ) : titleParts ? (
                <Fragment>{titleParts.before}<span class="section__title-highlight">{titleParts.highlight}</span>{titleParts.after}</Fragment>
              ) : (
                title
              )
            }
          </h2>
        )}
        {subtitle && <p class="section__subtitle">{subtitle}</p>}
      </div>
    )
  }
  <div class:list={['section__body', { 'section__body--narrow': narrow }]}>
    <slot />
  </div>
</section>

<style>
  /* Divider rhythm: a top border with equal space above and below the content,
     so sections read as evenly separated bands down the page. */
  .section {
    padding-block: var(--space-10);
    border-top: var(--border);
  }

  /*
   * Coloured variants render as full-bleed bands: `margin-inline: calc(50% -
   * 50vw)` pulls them out to the viewport edges and the matching `padding-inline`
   * re-aligns content with the container. (The body clips the resulting few px
   * of x-axis overflow — see global.css.)
   */
  .section--dark,
  .section--tinted {
    margin-inline: calc(50% - 50vw);
    padding-inline: calc(50vw - 50%);
    border-top: none;
  }

  /*
   * Dark band — re-declaring the colour tokens means every descendant that reads
   * them (text, cards, borders) inverts on its own. The highlight shifts to the
   * pale mint brand colour, which reads brightly against the slate.
   */
  .section--dark {
    background: #44575e;
    color: var(--color-text);
    --color-text: #f4f6f6;
    --color-text-muted: #c6d0d2;
    --color-text-subtle: #9fabad;
    --color-bg: rgba(255, 255, 255, 0.08);
    --color-surface: rgba(255, 255, 255, 0.08);
    --color-surface-hover: rgba(255, 255, 255, 0.12);
    --color-border: rgba(255, 255, 255, 0.18);
    --color-border-strong: rgba(255, 255, 255, 0.32);
    --color-accent: #c1fde8;
    --color-accent-hover: #a5f0d7;
    --color-focus: #c1fde8;
  }

  /*
   * Tinted band — a pale grey-blue surface. Text, the orange highlight and the
   * white cards are unchanged, so cards lift subtly off the tint.
   */
  .section--tinted {
    background: #f2f7f9;
  }

  /* The head → body gap. Kept a step above the tighter within-head rhythm
     (the eyebrow/title gaps use --space-3/--space-4) so a non-emphasis section
     title gets a little breathing space before its content. Emphasis heads
     override this with their own, larger gap below. */
  .section__head {
    max-width: var(--reading-width);
    margin-bottom: var(--space-6);
  }
  .section__eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }
  .section__eyebrow--accent2 {
    color: var(--color-accent-2);
  }
  .section__title {
    /* Matches the pre-hero-bump hero size, per the doc's request that every
       section headline read at the size the hero used to be. */
    font-size: var(--text-3xl);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-4);
  }
  /* Opt-in only (see `titleLineBreak` above) — applying this by default
     broke every `title` slot on .astro pages, since their own JSX-
     formatting whitespace/newlines started rendering as extra line breaks
     the moment this was a blanket rule. */
  .section__title--line-break {
    white-space: pre-line;
  }
  /* Matches the body's running text (.section-lead p): same base size, muted
     colour and line-height. The subtitle isn't used by any section today —
     its content was folded into the body — but it's kept for future use and
     styled to sit consistently with body copy rather than as a larger lede. */
  .section__subtitle {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin: 0;
  }
  .section__body--narrow {
    max-width: var(--reading-width);
  }

  /* Emphasis variant: the title reads as the page's feature, not just
     another section heading — centered, accent-coloured, and given extra
     breathing room above/below so it doesn't crowd its neighbours. */
  .section__head--emphasis {
    max-width: none;
    margin-top: var(--space-4);
    margin-bottom: var(--space-8);
    text-align: center;
  }
  .section__head--emphasis .section__subtitle {
    max-width: var(--reading-width);
    margin-inline: auto;
  }
  .section__title--emphasis {
    /* No size bump — emphasis titles read at the base title size (text-3xl)
       and are distinguished by centering and the accent colour alone. */
    color: var(--color-accent);
  }

  /* Partial-accent title (`titleHighlight`): the line stays in the default
     text colour — overriding the blanket accent `--emphasis` would otherwise
     apply — and only the highlighted phrase carries the accent. Declared after
     `--emphasis` so this wins the h2 base colour by source order. */
  .section__title--highlighted {
    color: var(--color-text);
  }
  .section__title-highlight {
    color: var(--color-accent);
  }

  /* Light-touch variant: centered only, no size/colour change. */
  .section__head--centered {
    max-width: none;
    text-align: center;
  }
  .section__head--centered .section__subtitle {
    max-width: var(--reading-width);
    margin-inline: auto;
  }
</style>
