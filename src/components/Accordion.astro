---
/**
 * Accordion — a single expand/collapse disclosure built on the native
 * <details>/<summary> element (closed by default): the heading is always
 * visible; the body only renders once opened. The `title` prop is the heading;
 * the revealed content is the default slot. A caret is the only affordance, and
 * the whole summary row is the click target, edge to edge.
 *
 * The title renders as an <h3>, matching the card-title level used elsewhere.
 * Stack several inside an `AccordionGroup` for consistent spacing between them.
 */
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<details class="accordion">
  <summary class="accordion__summary">
    <h3 class="accordion__title">{title}</h3>
    <svg class="accordion__caret" viewBox="0 0 16 16" aria-hidden="true">
      <path
        d="M4 6l4 4 4-4"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </summary>
  <div class="accordion__body">
    <slot />
  </div>
</details>

<style>
  .accordion {
    border: var(--border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }
  /* Padding lives on the summary/body rather than this container, so the
     summary's clickable area fills the card right up to the border instead of
     being inset from it. */
  .accordion__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5);
    list-style: none;
    cursor: pointer;
  }
  .accordion__summary::-webkit-details-marker {
    display: none;
  }
  .accordion__title {
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
  }
  .accordion__caret {
    width: 1rem;
    height: 1rem;
    color: var(--color-accent);
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }
  .accordion[open] .accordion__caret {
    transform: rotate(180deg);
  }
  /* Only shown when open. The summary's bottom padding provides the gap above,
     so pad just the sides and bottom here. Body text is slotted, so colour and
     inter-paragraph spacing are set on the container / global children. */
  .accordion__body {
    padding: 0 var(--space-5) var(--space-5);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }
  .accordion__body > :global(* + *) {
    margin-top: var(--space-3);
  }
</style>
