---
/**
 * Layout — the single site shell: <head>, header nav, main slot, footer.
 * Every page renders inside this so spacing, navigation and metadata stay
 * consistent.
 *
 * The header nav is Home (always first), then the Library app route and every
 * markdown page in the `pages` collection, interleaved by `order` — so dropping
 * a file into `src/content/pages/` makes it appear in the nav automatically. A
 * page can opt out with `nav: false`, and set its position with `order: <n>`
 * (lower first; ties fall back to alphabetical by label). Library is a fixed
 * route, so its own `order` is set below alongside the other fixed links.
 */
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Constrain the main content to a comfortable reading width (markdown pages). */
  narrow?: boolean;
}

const { title, description, narrow = false } = Astro.props;
const siteName = 'Open, Adaptive Digital Textbooks';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;

// `import.meta.env.BASE_URL` respects any configured `base` (GitHub Pages
// subpath) so internal links work in every deployment target.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Markdown pages as nav entries (excluding any opted out with `nav: false`),
// each carrying its `order` (default: last) for the shared sort below.
const pageLinks = (await getCollection('pages'))
  .filter((page) => page.data.nav)
  .map((page) => ({
    href: `${base}/${page.data.slug ?? page.id}`,
    label: page.data.title,
    order: page.data.order ?? Infinity,
  }));

// Library is a fixed app route (not a markdown page) but takes part in the same
// ordering, so a markdown page (e.g. Product) can sit before or after it.
const libraryLink = { href: `${base}/library`, label: 'Library', order: 2 };

// All non-Home links in nav order: `order` ascending, ties alphabetical by
// label. Home is always first.
const orderedLinks = [libraryLink, ...pageLinks].sort((a, b) => {
  if (a.order !== b.order) return a.order - b.order;
  return a.label.localeCompare(b.label);
});

const nav = [{ href: `${base}/`, label: 'Home' }, ...orderedLinks];
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
// The site root with any base path applied: '/textbooks-website' under a
// project subpath, or '/' at a domain root. Used to detect the Home link
// exactly, so its path isn't treated as a prefix of every other route.
const rootPath = base || '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="container site-header__inner">
        <div class="site-header__brand-group">
          <a class="site-header__brand" href={`${base}/`}>{siteName}</a>
          <p class="site-header__tagline">
            An <span class="site-header__tagline-accent">IDEMS</span> CommonTech STEM Education Project
          </p>
        </div>

        <button
          class="nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="Toggle menu"
        >
          <svg
            class="nav-toggle__icon nav-toggle__icon--open"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
          <svg
            class="nav-toggle__icon nav-toggle__icon--close"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="6" y1="18" x2="18" y2="6"></line>
          </svg>
        </button>

        <nav id="site-nav" class="site-nav" aria-label="Primary">
          {
            nav.map((item) => {
              const itemPath = item.href.replace(/\/$/, '') || '/';
              // The Home/root link must match exactly; otherwise its path would
              // prefix-match every route. Other links match the page or any
              // nested sub-route.
              const isCurrent =
                itemPath === rootPath
                  ? currentPath === rootPath
                  : currentPath === itemPath ||
                    currentPath.startsWith(itemPath + '/');
              return (
                <a
                  href={item.href}
                  class="site-nav__link"
                  aria-current={isCurrent ? 'page' : undefined}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
      </div>
    </header>

    <main id="main" class:list={['site-main', { 'site-main--narrow': narrow }]}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <p>
          This site is managed by <a target="_blank" href="https://www.idems.international/">IDEMS International<a>
        </p>
      </div>
    </footer>

    <style>
      .skip-link {
        position: absolute;
        left: var(--space-2);
        top: var(--space-2);
        transform: translateY(-200%);
        background: var(--color-text);
        color: #fff;
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-sm);
        z-index: 10;
      }
      .skip-link:focus {
        transform: translateY(0);
      }

      .site-header {
        border-bottom: var(--border);
        background: var(--color-bg);
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
        min-height: 3.5rem;
        padding-block: var(--space-4);
        flex-wrap: wrap;
      }
      .site-header__brand-group {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
      }
      .site-header__brand {
        font-weight: 600;
        font-size: var(--text-lg);
        line-height: var(--leading-tight);
        color: var(--color-text);
        letter-spacing: -0.01em;
      }
      .site-header__brand:hover {
        text-decoration: none;
      }
      .site-header__tagline {
        margin: 0;
        font-size: var(--text-xs);
        line-height: var(--leading-tight);
        color: var(--color-text-muted);
      }
      .site-header__tagline-accent {
        color: var(--color-accent);
        font-weight: 600;
      }

      /* Mobile menu toggle — hidden once the full nav fits (see media query). */
      .nav-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        padding: 0;
        border: 1px solid var(--color-border-strong);
        border-radius: var(--radius-sm);
        background: var(--color-bg);
        color: var(--color-text);
        cursor: pointer;
      }
      .nav-toggle:hover {
        background: var(--color-surface-hover);
      }
      .nav-toggle__icon--close {
        display: none;
      }
      .nav-toggle[aria-expanded='true'] .nav-toggle__icon--open {
        display: none;
      }
      .nav-toggle[aria-expanded='true'] .nav-toggle__icon--close {
        display: block;
      }

      /* Mobile: nav collapses onto its own full-width row, hidden until the
         toggle is expanded. The desktop rules below restore the inline row. */
      .site-nav {
        display: none;
        flex-basis: 100%;
        flex-direction: column;
        gap: var(--space-1);
        padding-top: var(--space-2);
      }
      .nav-toggle[aria-expanded='true'] ~ .site-nav {
        display: flex;
      }

      @media (min-width: 56rem) {
        .nav-toggle {
          display: none;
        }
        .site-nav {
          display: flex;
          flex-basis: auto;
          flex-direction: row;
          flex-wrap: wrap;
          padding-top: 0;
        }
      }
      .site-nav__link {
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        font-weight: 500;
        padding: var(--space-2) var(--space-3);
        border-radius: var(--radius-sm);
      }
      .site-nav__link:hover {
        color: var(--color-text);
        background: var(--color-surface-hover);
        text-decoration: none;
      }
      .site-nav__link[aria-current='page'] {
        color: var(--color-text);
        background: var(--color-surface-hover);
      }

      .site-main {
        /* Grow to absorb leftover vertical space so the footer sticks to the
           bottom of the viewport on short pages (see body flex column). */
        flex: 1 0 auto;
        padding-block: var(--space-8);
      }
      .site-main--narrow {
        /* reading-width constraint applied by inner .container of the page */
      }

      .site-footer {
        border-top: var(--border);
        background: var(--color-surface);
        margin-top: var(--space-10);
        color: var(--color-text-muted);
        font-size: var(--text-sm);
      }
      .site-footer__inner {
        padding-block: var(--space-6);
        max-width: var(--reading-width);
      }
      .site-footer p {
        margin: 0;
        text-align: center;
      }
    </style>

    <script>
      // Mobile nav: toggle the button's aria-expanded; CSS shows/hides the nav
      // and swaps the icon off that attribute. Escape closes it.
      const toggle = document.querySelector('.nav-toggle');
      if (toggle) {
        const setOpen = (open: boolean) =>
          toggle.setAttribute('aria-expanded', String(open));
        toggle.addEventListener('click', () => {
          setOpen(toggle.getAttribute('aria-expanded') !== 'true');
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setOpen(false);
        });
      }
    </script>
  </body>
</html>
