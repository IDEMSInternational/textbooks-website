---
/**
 * InterestForm — the "Register your interest" form on the Join page, submitting
 * to a Google Form. Lives in a component (not inline in the MDX) because its
 * client `<script>` and HTML comment aren't valid MDX. Styling comes from the
 * global `.form` classes.
 */
---

{/* Submits to a Google Form. `name` attributes are the Google Form `entry.*`
    field ids (from its pre-filled link); each checkbox group shares one id
    across its options and uses Google's `__other_option__` convention for the
    free-text "Other". */}
<form
  class="form"
  data-gform
  method="post"
  action="https://docs.google.com/forms/d/e/1FAIpQLSe_M86uPqBvrZAN5XK1HlSiS6lkgmbZeVQfADDc5fkow1Ce1w/formResponse"
>
  <div class="form__row">
    <div class="form__field">
      <label for="first-name">First name</label>
      <input
        type="text"
        id="first-name"
        name="entry.953194710"
        autocomplete="given-name"
        required
      />
    </div>
    <div class="form__field">
      <label for="last-name">Last name</label>
      <input
        type="text"
        id="last-name"
        name="entry.2097224968"
        autocomplete="family-name"
        required
      />
    </div>
  </div>
  <div class="form__field">
    <label for="email">Email</label>
    <input
      type="email"
      id="email"
      name="entry.1898684704"
      autocomplete="email"
      required
    />
  </div>
  <div class="form__field">
    <label for="role">Current role</label>
    <input
      type="text"
      id="role"
      name="entry.101676569"
      autocomplete="organization-title"
      required
    />
  </div>
  <div class="form__field">
    <label for="organisation">Institution / organisation</label>
    <input
      type="text"
      id="organisation"
      name="entry.646749844"
      autocomplete="organization"
      required
    />
  </div>
  <fieldset class="form__fieldset" data-require-one>
    <legend>I am… (select all that apply)</legend>
    <label class="form__check"
      ><input type="checkbox" name="entry.2111608256" value="An author" /> An
      author</label
    >
    <label class="form__check"
      ><input type="checkbox" name="entry.2111608256" value="An educator" /> An
      educator</label
    >
    <label class="form__check"
      ><input type="checkbox" name="entry.2111608256" value="A student" /> A
      student</label
    >
    <label class="form__check"
      ><input type="checkbox" name="entry.2111608256" value="A developer" /> A
      developer</label
    >
    <label class="form__check"
      ><input
        type="checkbox"
        name="entry.2111608256"
        value="__other_option__"
        data-other-checkbox
      /> Other</label
    >
    <input
      type="text"
      class="form__other"
      name="entry.2111608256.other_option_response"
      data-other-input
      aria-label="Other — please specify"
      placeholder="Please specify"
    />
  </fieldset>
  <fieldset class="form__fieldset" data-require-one>
    <legend>I'm interested in… (select all that apply)</legend>
    <label class="form__check"
      ><input
        type="checkbox"
        name="entry.1266014435"
        value="Contributing Resources"
      /> Contributing Resources</label
    >
    <label class="form__check"
      ><input
        type="checkbox"
        name="entry.1266014435"
        value="Research and Impact"
      /> Research and Impact</label
    >
    <label class="form__check"
      ><input
        type="checkbox"
        name="entry.1266014435"
        value="Open Software Development"
      /> Open Software Development</label
    >
    <label class="form__check"
      ><input type="checkbox" name="entry.1266014435" value="Testing" />
      Testing</label
    >
    <label class="form__check"
      ><input
        type="checkbox"
        name="entry.1266014435"
        value="Staying up-to-date"
      /> Staying up-to-date</label
    >
    <label class="form__check"
      ><input
        type="checkbox"
        name="entry.1266014435"
        value="__other_option__"
        data-other-checkbox
      /> Other</label
    >
    <input
      type="text"
      class="form__other"
      name="entry.1266014435.other_option_response"
      data-other-input
      aria-label="Other — please specify"
      placeholder="Please specify"
    />
  </fieldset>
  <div class="form__field">
    <label for="message">Message <span class="form__optional">(optional)</span></label>
    <textarea id="message" name="entry.1310602972" rows="4"></textarea>
  </div>
  <button type="submit" class="btn btn--primary">Submit</button>
</form>
<p class="form__status" id="join-form-status" role="status" tabindex="-1" hidden>
  Thanks — we've received your details and we'll be in touch.
</p>

<script>
  const form = document.querySelector('form[data-gform]');
  if (form instanceof HTMLFormElement) {
    const status = document.getElementById('join-form-status');

    // Keep each checkbox group's "Other" and its text field in sync: Google
    // needs the __other_option__ value selected alongside the free-text answer.
    // Scoped per fieldset so every group's pair is wired up independently.
    form.querySelectorAll('fieldset').forEach((fieldset) => {
      const otherCheck = fieldset.querySelector<HTMLInputElement>(
        '[data-other-checkbox]',
      );
      const otherInput = fieldset.querySelector<HTMLInputElement>(
        '[data-other-input]',
      );

      // Require at least one box in groups marked `data-require-one`. Native
      // checkbox `required` is per-box (it would force *every* box), so emulate
      // "pick at least one" by keeping `required` on a single representative box
      // only while nothing in the group is checked. Enforced via JS so no-JS
      // visitors aren't blocked — Google applies the same rule server-side.
      const boxes = Array.from(
        fieldset.querySelectorAll<HTMLInputElement>('input[type="checkbox"]'),
      );
      const requireOne = fieldset.hasAttribute('data-require-one')
        ? () => {
            const anyChecked = boxes.some((box) => box.checked);
            const [first] = boxes;
            if (first) {
              first.required = !anyChecked;
              // Replace the browser's default single-checkbox wording ("Please
              // tick this box if you want to proceed") with a group-appropriate
              // message; cleared once something is selected so the form validates.
              first.setCustomValidity(
                anyChecked ? '' : 'Please select at least one',
              );
            }
          }
        : null;
      if (requireOne) {
        boxes.forEach((box) => box.addEventListener('change', requireOne));
        requireOne();
      }

      if (otherCheck && otherInput) {
        otherInput.addEventListener('input', () => {
          if (otherInput.value.trim() !== '') {
            otherCheck.checked = true;
            // Setting `.checked` in code doesn't fire `change`, so dispatch one
            // to re-run the "Other" sync and the require-one check above.
            otherCheck.dispatchEvent(new Event('change'));
          }
        });
        otherCheck.addEventListener('change', () => {
          if (!otherCheck.checked) otherInput.value = '';
        });
      }
    });

    // Progressive enhancement: post in the background (Google Forms doesn't send
    // CORS headers, so the response is opaque) and keep the visitor on the page.
    // Native validation runs first, so this only fires for valid input. With JS
    // off, the form posts normally and lands on Google's confirmation page.
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      fetch(form.action, {
        method: 'POST',
        mode: 'no-cors',
        body: new FormData(form),
      })
        .then(() => {
          form.hidden = true;
          if (status) {
            status.hidden = false;
            status.focus();
          }
        })
        .catch(() => {
          if (status) {
            status.hidden = false;
            status.textContent =
              'Sorry — something went wrong sending the form. Please try again.';
            status.focus();
          }
        });
    });
  }
</script>
